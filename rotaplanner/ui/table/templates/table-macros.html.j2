
    
    
{% macro table_row(row, dates,cells,table_type) %}       
    <tr>
      <td class=table-row-header>{{ row.row_name }}</td>
      {%for date in dates%}       
          {{ table_cell(row, date, cells, table_type) }}
      {% endfor %}
          
    </tr>
{% endmacro %}

{%macro test_macro()%}
    <div>test</div>
{%endmacro%}

{% macro table_cell(row,date,cells,table_type)%}
  {% set cell = cells.get((row.row_id,date), []) %}
    <td class="table-activity-cell" id=cell--{{row.row_id}}--{{date.isoformat()}} data-class:dragover-valid="$droptarget==el">
      {% for activity in cell %}
      {%if table_type == "location"%}
          {{ location_activity(activity) }}
      {%elif table_type == "staff"%}
          {%if row.row_id%}
            {{ person_activity(activity, row.row_id) }}
          {%else%}
            {{ activity_without_allocated_staff(activity) }}
            {%endif%}
      {%else%}
          !{{table_type}}
      {%endif%}
      {% endfor %}
    </td>
{%endmacro%}

{%macro location_activity(activity)%}
    <div class=table-activity data-draggable="'.table-activity-cell'" 
         data-class="{'is-dragging':el==$dragged,'table-selected':$selection?.contains?.(el),'droptarget':$droptarget==el}"
      id=act--{{activity.id}}
    >
      <div class="table-activity-name">{{activity.name}}</div>
      <div class="table-activity-time">
        {{activity.activity_start.hour}} - {{activity.activity_finish.hour}}
      </div>
      <hr />
      <div>
      {%for timeslot in activity.timeslots%}
            <div class="table-timeslot" id="timeslot--{{timeslot.id}}" data-class:dragover-valid="$droptarget==el">
                <div class="table-activity-time">
                  {{timeslot.start.hour}} - {{timeslot.finish.hour}}
                </div>
                {%for assignment in timeslot.assignments%}
                <div class="table-assigned-staff" data-draggable="'.table-timeslot,.table-activity'" id="assn--{{assignment.id}}--{{assignment.staff.id}}">{{assignment.staff.name}}</div>
                {%else%}
                ...
                {%endfor%}
            </div>
        {%endfor%}
      </div>
    </div>
{%endmacro%}

{%macro activity_without_allocated_staff(activity)%}
<div class=table-activity data-draggable="'.table-activity-cell'" 
         data-class="{'is-dragging':el==$dragged,'table-selected':$selection?.contains?.(el),'droptarget':$droptarget==el}"
      id=act--{{activity.id}}
    >
      <div class="table-activity-name">{{activity.name}}</div>
      <div class="table-activity-time">
        {{activity.activity_start.hour}} - {{activity.activity_finish.hour}}
      </div>
      <hr />
      <div>
        
        {%for timeslot in activity.timeslots%}
        {% if not timeslot.assignments %}
            <div class="table-timeslot table-activity-time" 
              id="timeslot--{{timeslot.id}}" 
              data-draggable="'.table-activity-cell'">
              
                  {{timeslot.start.hour}} - {{timeslot.finish.hour}}
              </div>
                
            {%endif%}
        {%endfor%}
      </div>
    </div>

{%endmacro%}
{%macro person_activity(activity, staff_id)%}
    <div class=table-activity data-draggable="'.table-activity-cell'" 
         data-class="{'is-dragging':el==$dragged,'table-selected':$selection?.contains?.(el),'droptarget':$droptarget==el}"
      id=act--{{activity.id}}
    >
      <div class="table-activity-name">{{activity.name}}</div>
      <div class="table-activity-time">
        {{activity.activity_start.hour}} - {{activity.activity_finish.hour}}
      </div>
      <hr />
      <div>
        
        {%for timeslot in activity.timeslots%}
                
                {%for assignment in timeslot.assignments%}
                  {% if assignment.staff.id == staff_id %}
                    <div class="table-timeslot table-activity-time" data-draggable="'.table-activity-cell'" id="timeslot--{{timeslot.id}}">
                      {{timeslot.start.hour}} - {{timeslot.finish.hour}}
                    </div>
                  {% endif %}
                {% endfor %}
                
            
            
        {%endfor%}
      </div>
    </div>
{%endmacro%}

    
